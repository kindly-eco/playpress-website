
<article is="product">
  {% form 'product', product %}
    <h1>{{ product.title }}</h1>
    <p>{{ product.price | money }}</p>

    <select name="id" hidden>
      {%- for variant in product.variants -%}
        <option selected="selected" value="{{ variant.id }}"></option>
      {%- endfor -%}
    </select>
    {%- if product.available -%}
      <button type="submit">
        Add to Cart
      </button>
    {%- else -%}
      <p>Sold Out</p>
    {%- endif -%}
  {% endform %}

  {%- assign featured_image = product.featured_image -%}
  <img src="{{ featured_image | img_url: '1024x'}}" alt="{{ featured_image.alt | escape }}">

  <div is="gallery">
    {% for media in product.media %}
      <img
        class="product-single__thumbnail-image"
        src="{{ media | img_url: '600x' }}"
        alt="{{ thumbnailAlt }}
      ">
    {% endfor %}
  </div>

  <div>{{ product.description }}</div>

  <ul is="social-sharing">
    <li>
      <a target="_blank" href="//www.facebook.com/sharer.php?u={{ shop.url | append: product.url }}" class="btn btn--small btn--share share-facebook">
        Facebook
        <span class="share-title" aria-hidden="true">{{ 'general.social.share_on_facebook' | t }}</span>
        <span class="visually-hidden">{{ 'general.social.alt_text.share_on_facebook' | t }}</span>
      </a>
    </li>
    <li>
      <a target="_blank" href="//twitter.com/share?text={{ product.title | url_param_escape }}&amp;url={{ shop.url | append: product.url }}" class="btn btn--small btn--share share-twitter">
        Twitter
        <span class="share-title" aria-hidden="true">{{ 'general.social.share_on_twitter' | t }}</span>
        <span class="visually-hidden">{{ 'general.social.alt_text.share_on_twitter' | t }}</span>
      </a>
    </li>
    <li>
      <a target="_blank" href="//pinterest.com/pin/create/button/?url={{ shop.url | append: product.url }}&amp;media={{ product.featured_media | img_url: '1024x1024' }}&amp;description={{ product.title | url_param_escape }}" class="btn btn--small btn--share share-pinterest">
        Pinterest
        <span class="share-title" aria-hidden="true">{{ 'general.social.share_on_pinterest' | t }}</span>
        <span class="visually-hidden">{{ 'general.social.alt_text.share_on_pinterest' | t }}</span>
      </a>
    </li>
  </ul>

  <p is="delivery"> <svg fill="none" width="30" height="27" viewBox="0 0 30 27"> <path fill="hsl(var(--sea-1))" d="M22.7 17.8a3.8 3.8 0 100 7.6 3.8 3.8 0 000-7.6zm0 5.7a1.9 1.9 0 110-3.8 1.9 1.9 0 010 3.8zm-13-5.7a3.8 3.8 0 100 7.6 3.8 3.8 0 000-7.6zm0 5.7a1.9 1.9 0 110-3.8 1.9 1.9 0 010 3.8zM25.2 7a.9.9 0 00-.8-.5h-5v1.9h4.4l2.6 5 1.7-.7L25.2 7z"></path> <path fill="hsl(var(--sea-1))" d="M12.7 20.7h7.1v2h-7.1v-2zm-5.8 0H3.6a1 1 0 000 2H7a1 1 0 000-2zm23-5.8l-2-2.4a1 1 0 00-.7-.3h-6.9V5.6c0-.6-.4-1-1-1H3.7a1 1 0 000 1.9h14.9v6.6c0 .6.4 1 .9 1h7.3l1.4 1.7v4.9h-2.6a1 1 0 000 2H29c.5 0 .9-.6.9-1v-6.2c0-.2 0-.4-.2-.6zm-23 1H2.5a1 1 0 000 2h4.4a1 1 0 000-2zM9 12.2H1A1 1 0 001 14h8a1 1 0 000-2z"></path> <path fill="hsl(var(--sea-1))" d="M10.5 8.5h-8a1 1 0 000 1.9h8a1 1 0 000-1.9z"></path> </svg> <em>We deliver worldwide - UK orders are free of charge.</em> </p>

</article>
