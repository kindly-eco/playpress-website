    <footer is="footer" role="contentinfo">
      <div>
        {% include 'site-nav', linklist: section.settings.footer_linklist %}
        <dark-mode-toggle id="dark-mode-toggle" label="Dark mode"></dark-mode-toggle>
        {{ section.settings.feedback_text }}

        {%- if section.blocks.size > 0 -%}
        <ul>
          {%- for block in section.blocks -%}
          <li {{ block.shopify_attributes }}>
            {%- if block.settings.link_text != blank -%}
              <a href="{{ block.settings.link_url }}">
                {{ block.settings.link_text }}
                {{ block.settings.link_image }}
              </a>
            {%- endif -%}
          </li>
          {%- endfor -%}
        </ul>
        {%- endif -%}

        <p>
          This website was crafted by <a href="https://www.kindly.eco">Kindly</a> to be eco-friendly.
        </p>
        <p>
          <small>Copyright 2020 Playpress</small>
        </p>
      </div>
    </footer>
    {% schema %}
    {
    "name": "Footer",
    "settings": [
      {
      "type": "link_list",
      "id": "footer_linklist",
      "label": "Footer menu",
      "default": "footer"
      },
      {
      "type": "richtext",
      "id": "feedback_text",
      "label": "Feedback text",
      "default": "<p>Tell us more!</p>"
      },
      {
      "type": "image_picker",
      "id": "footer_image",
      "label": "Footer image"
      }
    ],
    "blocks": [
      {
        "type": "text",
        "name": "Social links",
        "settings": [
          {
            "type": "text",
            "id": "link_text",
            "label": "Link text"
          },
          {
            "type": "url",
            "id": "link_url",
            "label": "Link URL"
          },
          {
            "type": "image_picker",
            "id": "link_image",
            "label": "Link image"
          }

        ]
      }
    ]
    }
    {% endschema %}
