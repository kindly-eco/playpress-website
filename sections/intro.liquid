<section is="intro" {%- if section.settings.image != blank -%}class="with-image"{%- endif -%}>
  <div>
    {%- if section.settings.heading != blank -%}
      <h1>{{ section.settings.heading | escape }}</h1>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p is="lede">{{ section.settings.text }}</p>
    {%- endif -%}
  </div>
  {%- if section.settings.image != blank -%}
  <img
    src="{{ section.settings.image | img_url: 'master' }}"
    alt=""
    width="900"
    height="600"
    is="in-action"
  />
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Intro",
  "settings": [ {
    "id": "heading",
    "type": "text",
    "label": "Heading"
  },
  {
  "id": "text",
  "type": "text",
  "label": "Text"
  },
  {
  "id": "image",
  "type": "image_picker",
  "label": "Image"
  } ],
  "presets": [ {
  "name": "Intro",
  "category": "Image"
  } ] }
{% endschema %}
